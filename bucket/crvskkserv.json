{
    "version": "2.5.6",
    "description": "win32 skk server with DICTS.",
    "homepage": "https://github.com/nathancorvussolis/crvskkserv",
    "checkver": "github",
    "bin": "crvskkserv.exe",
    "pre_install": [
        "if(!(test-path \"$persist_dir\\crvskkserv.ini\")) {",
        "   New-Item -ItemType File $dir\\crvskkserv.ini",
        "}"
    ],
    "depends": [
        "nkf",
        "skktools"
    ],
    "persist": [
        "crvskkserv.ini",
        "DICTS"
    ],
    "post_install": [
        "if (!(Get-Content $persist_dir\\crvskkserv.ini)) {",
        "@\"",
        "[crvskkserv]",
        "port=1178",
        "loopback=1",
        "googlecgiapi_url_prefix=https://www.google.com/transliterate?langpair=ja-Hira|ja&text=",
        "googlecgiapi_url_suffix=,",
        "dic-1=$persist_dir\\DICTS\\SKK-JISYO.L.utf8",
        "dic-2=$persist_dir\\DICTS\\SKK-JISYO.jinmei.utf8",
        "dic-3=$persist_dir\\DICTS\\SKK-JISYO.geo.utf8",
        "dic-4=$persist_dir\\DICTS\\SKK-JISYO.station.utf8",
        "dic-5=$persist_dir\\DICTS\\SKK-JISYO.propernoun.utf8",
        "dic-6=$persist_dir\\DICTS\\SKK-JISYO.jawiki.utf8",
        "dic-7=$persist_dir\\DICTS\\SKK-JISYO.hatena.utf8",
        "dic-8=$persist_dir\\DICTS\\SKK-JISYO.niconico.utf8",
        "dic-9=$persist_dir\\DICTS\\SKK-JISYO.emoji.utf8",
        "dic-10=$persist_dir\\DICTS\\SKK-JISYO.emoji-ja.utf8",
        "dic-11=googlecgiapi/[^A-Za-z0-9]+[a-z]/G/500/utf-8/",
        "\"@ > $dir\\crvskkserv.ini",
        "}",
        "cd $dir\\DICTS",
        "curl.exe -sLO https://skk-dev.github.io/dict/SKK-JISYO.L.gz",
        "curl.exe -sLO https://skk-dev.github.io/dict/SKK-JISYO.jinmei.gz",
        "curl.exe -sLO https://skk-dev.github.io/dict/SKK-JISYO.geo.gz",
        "curl.exe -sLO https://skk-dev.github.io/dict/SKK-JISYO.station.gz",
        "curl.exe -sLO https://skk-dev.github.io/dict/SKK-JISYO.propernoun.gz",
        "curl.exe -sLO https://github.com/ymrl/SKK-JISYO.emoji-ja/raw/master/SKK-JISYO.emoji-ja.utf8",
        "curl.exe -sLO https://github.com/uasi/skk-emoji-jisyo/raw/master/SKK-JISYO.emoji.utf8",
        "curl.exe -sLo SKK-JISYO.jawiki.utf8 https://github.com/tokuhirom/jawiki-kana-kanji-dict/raw/master/SKK-JISYO.jawiki",
        "curl.exe -sLO https://gist.github.com/hirsaeki/376948d2cce4e3cba1b40758f686699d/raw/0cf1f0275967bb01bfe41ac18cf38aaebdb66672/SKK-JISYO.hatena.utf8",
        "curl.exe -sLO https://tkido.com/nicoime/nicoime.zip",
        "7z.exe -y e nicoime.zip",
        "if (!(Test-Path 'nicoime_atok.txt')) { throw 'nicoime_atok.txt was not found after extracting niconico.zip' }",
        "$inputPath = \"$dir\\DICTS\\nicoime_atok.txt\"",
        "$outputPath = \"$dir\\DICTS\\SKK-JISYO.niconico.utf8\"",
        "$expectedPos = '固有一般*'",
        "$entries = [System.Collections.Generic.List[string]]::new()",
        "$unexpectedPos = [System.Collections.Generic.HashSet[string]]::new()",
        "$updated = $null",
        "$normalizedUnsafe = 0",
        "$utf8NoBom = [System.Text.UTF8Encoding]::new($false)",
        "$reader = [System.IO.StreamReader]::new($inputPath, $utf8NoBom, $true)",
        "try {",
        "    while (($line = $reader.ReadLine()) -ne $null) {",
        "        if ([string]::IsNullOrWhiteSpace($line)) { continue }",
        "        if ($line.StartsWith('!!')) {",
        "            if (-not $updated) {",
        "                $match = [regex]::Match($line, ';(.*:\\d\\d)')",
        "                if ($match.Success) { $updated = $match.Groups[1].Value }",
        "            }",
        "            continue",
        "        }",
        "        $parts = $line.Split(\"`t\")",
        "        for ($i = 0; $i -lt $parts.Length; $i++) { $parts[$i] = $parts[$i].Trim() }",
        "        if ($parts.Length -lt 2 -or [string]::IsNullOrEmpty($parts[0]) -or [string]::IsNullOrEmpty($parts[1])) { continue }",
        "        $yomi = $parts[0]",
        "        $candidate = $parts[1]",
        "        $pos = if ($parts.Length -ge 3) { $parts[2] } else { '' }",
        "        if ($pos -and $pos -ne $expectedPos) { [void]$unexpectedPos.Add($pos); continue }",
        "        if ($candidate.Contains('/') -or $candidate.Contains(';')) {",
        "            $candidate = $candidate.Replace('/', '／').Replace(';', '；')",
        "            $normalizedUnsafe++",
        "        }",
        "        $entries.Add(\"$yomi /$candidate/\")",
        "    }",
        "}",
        "finally {",
        "    $reader.Dispose()",
        "}",
        "$header = [System.Collections.Generic.List[string]]::new()",
        "$header.Add(';; skk-nico-ime')",
        "$header.Add(';; original: https://tkido.com/nicoime/')",
        "if ($updated) { $header.Add(\";; updated: $updated\") }",
        "$header.Add(';; okuri-ari entries.')",
        "$header.Add(';; okuri-nasi entries.')",
        "$writer = [System.IO.StreamWriter]::new($outputPath, $false, $utf8NoBom)",
        "try {",
        "    foreach ($headerLine in $header) { $writer.WriteLine($headerLine) }",
        "    $writer.WriteLine()",
        "    foreach ($entry in $entries) { $writer.WriteLine($entry) }",
        "}",
        "finally {",
        "    $writer.Dispose()",
        "}",
        "if ($unexpectedPos.Count -gt 0) { Write-Warning (\"Unexpected POS skipped: {0}\" -f ([string]::Join(', ', ($unexpectedPos | Sort-Object)))) }",
        "if ($normalizedUnsafe -gt 0) { Write-Warning (\"Normalized {0} candidates containing '/' or ';'\" -f $normalizedUnsafe) }",
        "Remove-Item *.txt",
        "Remove-Item *.zip",
        "7z.exe -y e *.gz",
        "Remove-Item *.gz",
        "ls -Name -Include \"SKK-JISYO.*\" -Exclude \"*.utf8\" | %{cmd.exe /c \"type $_ | nkf -w -Lu > $_.utf8\"; if ($?) {Remove-Item $_} }",
        "ls -Name -Include \"SKK-JISYO.*.utf8\" | %{ (Get-Content $_ -Raw).Replace(\"う゛\", \"ゔ\") | Set-Content $_ }"
    ],
    "shortcuts": [
        [
            "crvskkserv.exe",
            "crvskkserv"
        ]
    ],
    "license": "MS-PL",
    "architecture": {
        "64bit": {
            "url": "https://github.com/nathancorvussolis/crvskkserv/releases/download/2.5.6/crvskkserv-2.5.6-x64.zip",
            "hash": "8e36c5f9b43f951b011f7faabe93aac465c1ac84a4c71eae8f30bdd7ff9f65a1"
        },
        "32bit": {
            "url": "https://github.com/nathancorvussolis/crvskkserv/releases/download/2.5.6/crvskkserv-2.5.6-x86.zip",
            "hash": "13859051e26728bcb968f55e36d41574ff6faa34f13d63103e7e7892e975d137"
        }
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nathancorvussolis/crvskkserv/releases/download/$version/crvskkserv-$version-x64.zip"
            },
            "32bit": {
                "url": "https://github.com/nathancorvussolis/crvskkserv/releases/download/$version/crvskkserv-$version-x86.zip"
            }
        }
    }
}

